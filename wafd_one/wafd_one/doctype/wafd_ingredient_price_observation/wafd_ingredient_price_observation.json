    {
      "fieldname": "availability",
      "fieldtype": "Select",
      "label": "التوفر / Availability",
      "options": "متوفر / Available\nغير متوفر / Out of Stock\nغير مؤكد / Unknown",
      "default": "غير مؤكد / Unknown"
    },
    {
      "fieldname": "price_type",
      "fieldtype": "Select",
      "label": "نوع السعر / Price Type",
      "options": "تجزئة / Retail\nجملة / Wholesale\nعرض / Promotion\nفاتورة مورد / Supplier Invoice",
