{
  "doctype": "DocType",
  "name": "WAFD Delivery Proof",
  "module": "WAFD ONE",
  "custom": 0,
  "autoname": "format:POD-.YYYY.-.#####",
  "engine": "InnoDB",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "delivery_trip",
      "label": "رحلة التوصيل / Delivery Trip",
      "fieldtype": "Link",
      "options": "WAFD Delivery Trip",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "delivered_qty",
      "label": "الكمية المسلمة / Delivered Qty",
      "fieldtype": "Int",
      "reqd": 1
    },
    {
      "fieldname": "receiver_name",
      "label": "اسم المستلم / Receiver Name",
      "fieldtype": "Data",
      "reqd": 1
    },
    {
      "fieldname": "delivery_time",
      "label": "وقت التسليم / Delivery Time",
      "fieldtype": "Datetime",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "gps_location",
      "label": "الموقع GPS",
      "fieldtype": "Geolocation"
    },
    {
      "fieldname": "before_loading_photo",
      "label": "صورة قبل التحميل / Before Loading",
      "fieldtype": "Attach Image"
    },
    {
      "fieldname": "arrival_photo",
      "label": "صورة الوصول / Arrival Photo",
      "fieldtype": "Attach Image"
    },
    {
      "fieldname": "after_delivery_photo",
      "label": "صورة بعد التسليم / After Delivery",
      "fieldtype": "Attach Image"
    },
    {
      "fieldname": "receiver_signature",
      "label": "توقيع المستلم / Signature",
      "fieldtype": "Signature"
    },
    {
      "fieldname": "delivery_status",
      "label": "حالة التسليم / Status",
      "fieldtype": "Select",
      "options": "تم\\nناقص\\nمرفوض\\nمتأخر",
      "default": "تم",
      "in_list_view": 1
    },
    {
      "fieldname": "remarks",
      "label": "ملاحظات / Remarks",
      "fieldtype": "Small Text"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1
    },
    {
      "role": "Projects Manager",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}