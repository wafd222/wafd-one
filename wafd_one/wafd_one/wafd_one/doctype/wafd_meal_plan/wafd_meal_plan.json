      "default": "مخطط",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 0
    },
    {
      "role": "Projects Manager",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
