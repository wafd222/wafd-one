      "label": "الفندق / Hotel",
      "fieldtype": "Link",
      "options": "WAFD Hotel",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "service_date",
      "label": "التاريخ / Date",
      "fieldtype": "Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
