{
  "doctype": "DocType",
  "name": "WAFD Meal Plan",
  "module": "WAFD ONE",
  "custom": 0,
  "autoname": "format:MP-.YYYY.-.#####",
  "engine": "InnoDB",
  "is_submittable": 0,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "project",
      "label": "المشروع / Project",
      "fieldtype": "Link",
      "options": "WAFD Catering Project",
      "reqd": 1,
      "in_list_view": 1
    },
    {
